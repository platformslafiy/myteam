# Backend environment configuration
# Copy this file to ".env" and adjust as needed.

# Database connection string.
# Leave UNSET to use the default: an absolute path to backend/team_timeline.db
# (resolved from the app package location, so it is the same regardless of the
# process working directory). Only set this to override.
# SQLite example (absolute path recommended):
# DATABASE_URL=sqlite:///C:/slafiy/projects/myteam/backend/team_timeline.db
# PostgreSQL (production-ready, just swap the URL — no code change needed):
# DATABASE_URL=postgresql+psycopg2://user:password@localhost:5432/team_timeline

# Port the API server listens on. Default 8080 (port 8000 is left free on purpose).
APP_PORT=8080

# Comma-separated list of origins allowed to call the API (frontend dev server).
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Set to "true" to drop & recreate + reseed the DB on startup (dev only).
SEED_ON_STARTUP=false
